<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1A1A2E">

    <!-- App title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="#E0E0E0"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <!-- Disc / note icon placeholder -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="\uD83C\uDFB5"
        android:textSize="64sp"
        android:layout_marginBottom="24dp" />

    <!-- File name display -->
    <TextView
        android:id="@+id/tvFileName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_file_selected"
        android:textColor="#B0B0C0"
        android:textSize="14sp"
        android:gravity="center"
        android:ellipsize="middle"
        android:singleLine="true"
        android:layout_marginBottom="8dp" />

    <!-- Status label -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_no_file"
        android:textColor="#7EC8C8"
        android:textSize="13sp"
        android:layout_marginBottom="32dp" />

    <!-- Browse button -->
    <Button
        android:id="@+id/btnBrowse"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="@string/btn_browse"
        android:textColor="#FFFFFF"
        android:backgroundTint="#16213E"
        android:layout_marginBottom="12dp" />

    <!-- Play / Pause button -->
    <Button
        android:id="@+id/btnPlayPause"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="@string/btn_play"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0F3460"
        android:enabled="false"
        android:layout_marginBottom="12dp" />

    <!-- Stop button -->
    <Button
        android:id="@+id/btnStop"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="@string/btn_stop"
        android:textColor="#FFFFFF"
        android:backgroundTint="#533483"
        android:enabled="false" />

</LinearLayout>
